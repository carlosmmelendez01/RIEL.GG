# RIEL OS — environment variables
# Copy this file to `.env.local` and fill in the values from Supabase + Vercel.

# --- Supabase (client) -----------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase (server) -----------------------------------------------------
# Used by Prisma. Pooled connection (port 6543) for runtime, direct (5432) for migrations.
DATABASE_URL=
DIRECT_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- App -------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Email (Resend) --------------------------------------------------------
# Get RESEND_API_KEY at https://resend.com/api-keys. Without it, the app falls
# back to console-logging emails — every flow keeps working in dev without
# anything wired up.
# RESEND_FROM_ADDRESS must use a domain you've verified in Resend (or the
# `onboarding@resend.dev` sandbox, which only delivers to your account email).
RESEND_API_KEY=
RESEND_FROM_ADDRESS=RIEL.GG <hello@riel.gg>

# --- Beta / demo -----------------------------------------------------------
# Set both to "true" to enable the one-click demo sign-in launcher at /dev,
# even in production. Leave unset for a fully locked-down deploy.
ENABLE_DEMO_AUTH=true
NEXT_PUBLIC_ENABLE_DEMO_AUTH=true

# Shared beta access password. When set, the entire site is locked behind a
# /beta-gate page until a visitor enters this. Leave blank to disable the gate.
BETA_ACCESS_PASSWORD=

# Where in-app "Send feedback" submissions are emailed. Requires RESEND_API_KEY
# to actually deliver; otherwise feedback is only stored in the DB.
FEEDBACK_EMAIL=

# Comma-separated emails allowed into the (still mock) /platform/* SaaS admin.
# Closed by default — everyone else is redirected to /dashboard.
PLATFORM_ADMIN_EMAILS=

